rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == "regisservicecuritiba@gmail.com" ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'ADMIN'
      );
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Clientes
    match /clients/{clientId} {
      allow get: if true; // Allow public viewing for PMOC
      allow list: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Equipamentos
    match /machines/{machineId} {
      allow get: if true; // Allow public viewing for PMOC
      allow list: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Ordens de Serviço
    match /orders/{orderId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Peças
    match /parts/{partId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Serviços
    match /services/{serviceId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // PMOC
    match /pmocs/{pmocId} {
      allow get: if true; // Allow public viewing of a single PMOC via link
      allow list: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Manutenções
    match /maintenance_sessions/{sessionId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Usuários (Perfis)
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId) || isAdmin();
    }
  }
}
